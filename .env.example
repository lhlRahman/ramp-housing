# Backend
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
SCRAPE_CACHE_TTL_SECONDS=0

# AI (Grok — used for filter parsing + SMS generation)
XAI_API_KEY=

# Retell (voice agent)
RETELL_API_KEY=
RETELL_DEFAULT_FROM_NUMBER=
RETELL_DEFAULT_VOICE_AGENT_ID=
RETELL_DEFAULT_CHAT_AGENT_ID=
INTERNAL_ESCALATION_WEBHOOK_URL=
INTERNAL_ESCALATION_WEBHOOK_BEARER_TOKEN=

# Twilio (direct SMS — bypasses Retell for texting)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# Geocoder
NOMINATIM_URL=https://nominatim.openstreetmap.org/search
NOMINATIM_RATE_LIMIT=1.0
NOMINATIM_USER_AGENT=ramp-intern-housing/1.0

# Scraper
SCRAPER_TIMEOUT=40000
SCRAPER_MAX_PAGES=5
BROWSER_HEADLESS=true

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
